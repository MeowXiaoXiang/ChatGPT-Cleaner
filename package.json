{
    "name": "chatgpt-cleaner",
    "version": "1.1.0",
    "description": "ChatGPT 訊息清理小工具",
    "type": "module",
    "packageManager": "yarn@4.12.0",
    "engines": {
        "node": ">=20.0.0"
    },
    "private": true,
    "scripts": {
        "clean": "rimraf dist",
        "typecheck": "tsc --noEmit && echo Type check passed",
        "build": "yarn clean && yarn typecheck && cross-env NODE_ENV=production node esbuild.config.mjs",
        "dev": "cross-env NODE_ENV=development WATCH=1 node esbuild.config.mjs",
        "zip": "node scripts/zip.js",
        "postinstall": "node scripts/postinstall.js"
    },
    "devDependencies": {
        "@types/archiver": "^7.0.0",
        "@types/chrome": "0.1.38",
        "archiver": "^7.0.1",
        "cross-env": "10.1.0",
        "esbuild": "0.27.4",
        "rimraf": "6.1.3",
        "typescript": "5.9.3"
    }
}
