* text=auto

# Source and docs: normalize to LF in the repo
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.svg text eol=lf
*.py text eol=lf
*.txt text eol=lf
*.map text eol=lf
*.lock text eol=lf
.gitignore text eol=lf
LICENSE text eol=lf

# Windows shell scripts should keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.exe binary
